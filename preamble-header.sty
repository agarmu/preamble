%% ===========================================================================
%% HEADER --- Document structure, fonts, typography, and visual setup
%% ===========================================================================
\ProvidesPackage{preamble-header}

%% --- Encoding ------------------------------------------------------------
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc} % explicit UTF-8 support for pdfTeX

%% --- Utility packages ----------------------------------------------------
\usepackage{etoolbox}   % \ifstrempty, \AtBeginEnvironment, \undef, toggles
\usepackage{xparse}     % \NewDocumentEnvironment etc.
\usepackage{xspace}     % smart spacing after command names
\usepackage{needspace}  % \Needspace to prevent awkward page breaks

%% --- Page layout ---------------------------------------------------------
\usepackage{geometry}
\geometry{
    hmarginratio={1:1},
    vmarginratio={1:1},
    includehead,
    includefoot,
    heightrounded,
    footskip=2\baselineskip,
    headheight=1.8\baselineskip,
    headsep=0.5\baselineskip,
    textheight=0.75\paperheight,
    textwidth=0.75\paperwidth,
}

\usepackage{titling}
\setlength{\droptitle}{-0.1\textheight}

%% --- Headers & footers ---------------------------------------------------
\usepackage{fancyhdr}
\usepackage{lastpage}

\fancypagestyle{plain}{%
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \fancyfoot[C]{{\bfseries\thepage} of {\bfseries\pageref*{LastPage}}}
}

\fancypagestyle{fancy}{%
    \fancyhf{}
    \renewcommand{\headrulewidth}{0.5pt}
    \fancyhead[L]{\bfseries\thetitle}
    \fancyhead[R]{\bfseries\theauthor}
    \fancyfoot[C]{{\bfseries\thepage} of {\bfseries\pageref*{LastPage}}}
}

%% --- Fonts ---------------------------------------------------------------
\usepackage{libertinus}            % Libertinus Serif + Sans for pdfTeX
\usepackage[scale=0.95]{inconsolata}  % Monospace font

%% --- Math fonts ----------------------------------------------------------
\usepackage{mathtools}             % loads amsmath; extends it
\usepackage{amssymb}               % AMS symbols (\varnothing, \mathbb, etc.)
\usepackage{libertinust1math}      % Libertinus math fonts for pdfTeX
\usepackage[cal=cm,scr=rsfso,bb=ams]{mathalpha} % calligraphic, script & bb

%% --- Typographic refinements ---------------------------------------------
\usepackage{silence}
\WarningFilter{latex}{Command \showhyphens   has changed.}
\WarningFilter{latex}{Command \underbar  has changed.}
\WarningFilter{latex}{Command \underline  has changed.}

\usepackage[
    protrusion,
    expansion,
    activate={true,nocompatibility},
    tracking=true,
    letterspace
]{microtype}

%% --- Language ------------------------------------------------------------
\usepackage[french,german,english]{babel} % last language = default

%% --- Table of contents ---------------------------------------------------
\usepackage{tocloft}
\addto\captionsenglish{% override babel's default "Contents"
    \renewcommand{\contentsname}{Table of Contents}%
}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftsecindent}{1.5em}
\setlength{\cftsubsecindent}{3.0em}
\renewcommand{\cftsecfont}{}
\renewcommand{\cftsecpagefont}{}

%% --- Paragraphs & spacing ------------------------------------------------
\usepackage{parskip}
\usepackage[normalem]{ulem} % \uline for underlining; keeps \emph as italic

%% --- Section styling -----------------------------------------------------
\usepackage{sectsty}
\allsectionsfont{\bfseries}
\partfont{\normalfont\centering\scshape\Huge}

\let\oldpart\part
\renewcommand{\part}[1]{%
    \clearpage
    \thispagestyle{plain}
    \vspace*{0pt plus 1fill}
    \oldpart{#1}
    \vspace*{0pt plus 3fill}
    \clearpage
}

%% --- Colors, figures, tables, lists --------------------------------------
\usepackage[rgb,svgnames]{xcolor}
\usepackage{graphicx}
\usepackage{booktabs}
\usepackage{caption}
\usepackage{enumitem}
\usepackage{tabularx}
\usepackage{float}

\setlist[enumerate]{leftmargin=1.5em}
\setlist[itemize]{leftmargin=1.5em}
\setlist[description]{leftmargin=1.5em}
\newcommand\bitem{\item[\textbullet]}

%% --- Hyperlinks & cross-references ---------------------------------------
\usepackage{hyperref}
\hypersetup{
    colorlinks,
    allcolors=blue!70!black,
}
\usepackage{xurl}
\RequirePackage[nameinlink]{cleveref}

%% --- Drawing (TikZ & pgfplots) ------------------------------------------
\usepackage{tikz}
\usetikzlibrary{arrows.meta}
\usetikzlibrary{decorations.markings}
\usetikzlibrary{decorations.pathmorphing}
\usetikzlibrary{positioning}
\usetikzlibrary{fadings}
\usetikzlibrary{intersections}
\usetikzlibrary{cd}
\usetikzlibrary{patterns, patterns.meta}

\usepackage{pgfplots}
\pgfplotsset{compat=1.18}

%% --- Boxes ---------------------------------------------------------------
\usepackage[breakable,hooks,skins]{tcolorbox}
\usepackage{footnotehyper}
\makesavenoteenv{tcolorbox}

\endinput
